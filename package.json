{
  "name": "everbee-store-app-template",
  "version": "1.0.0",
  "description": "Full-stack template for building EverBee Store apps with AI",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "setup": "./scripts/setup.sh",
    "dev": "./scripts/dev.sh",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "db:seed": "cd backend && tsx seed/seed.ts",
    "deploy": "./scripts/deploy.sh"
  },
  "keywords": [
    "everbee",
    "store",
    "app",
    "template",
    "ai",
    "cursor"
  ],
  "author": "EverBee",
  "license": "MIT"
}

# MongoDB Atlas (get from https://www.mongodb.com/atlas)
MONGODB_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/everbee_store_app

# EverBee Store OAuth (get from https://store.everbee.io/admin/apps)
EVERBEE_CLIENT_ID=your_client_id_here
EVERBEE_CLIENT_SECRET=your_client_secret_here
EVERBEE_REDIRECT_URI=http://localhost:3001/api/auth/callback
EVERBEE_AUTH_URL=https://auth.everbee.com/oauth

# JWT Secret (auto-generated by setup script)
JWT_SECRET=your-secret-key-change-in-production

# Server
PORT=3001
NODE_ENV=development

# Frontend URL
FRONTEND_URL=http://localhost:3000

# App identity (shown in OpenAPI, llms.txt, schema.org, How It Works)
APP_NAME=My EverBee App
APP_DESCRIPTION=An app built on the EverBee Store platform.
APP_VERSION=1.0.0

# Public origin of the deployed app (advertised in OpenAPI/llms.txt/sitemap).
# Set automatically by scripts/deploy-fly.sh to https://<app-name>.fly.dev
PUBLIC_URL=http://localhost:3001

# Visibility: "public" = LLM-crawlable + hosted MCP at /mcp by default.
# Set to "private" to block AI crawlers (robots.txt Disallow: /) AND disable /mcp.
APP_VISIBILITY=public

# Product analytics — PostHog (standing build standard). Leave blank to no-op
# locally. Get a project key at https://posthog.com (Project settings → API key).
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
